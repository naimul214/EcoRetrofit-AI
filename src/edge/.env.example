# Edge service environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# IMPORTANT: When switching networks (home Wi-Fi -> iPhone hotspot),
# you MUST update all IP addresses below to the Command Center's
# new IP on the current network. iPhones typically use 172.20.10.x.
# Find it with: ipconfig (Windows) or ifconfig (Mac/Linux).

# InfluxDB connection (running on Command Center / ThinkPad)
INFLUXDB_URL=http://172.20.10.X:8086
INFLUXDB_ADMIN_TOKEN=your_token_here
INFLUXDB_ORG=ecoretrofit
INFLUXDB_BUCKET=ecoretrofit_telemetry
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=your_password_here

# FastAPI backend URL (running on Command Center / ThinkPad)
BACKEND_API_URL=http://172.20.10.X:8010/api/environment

# BACnet target device (set to Command Center IP for Chipkin Explorer capture)
BACNET_DEVICE_ADDR=172.20.10.X
BACNET_OBJECT_ID=analogValue:1
