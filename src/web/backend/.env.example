# Backend service settings
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ADMIN_TOKEN=your_token_here
INFLUXDB_ORG=ecoretrofit
INFLUXDB_BUCKET=ecoretrofit_telemetry

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Ontario TOU rates in CAD/kWh
TOU_OFF_PEAK_CAD_PER_KWH=0.087
TOU_MID_PEAK_CAD_PER_KWH=0.122
TOU_ON_PEAK_CAD_PER_KWH=0.182

# Proxy energy model defaults
BASELINE_HVAC_KW=12.0
BASELINE_DEADBAND_C=2.0
MIN_POWER_FACTOR=0.55
MAX_POWER_FACTOR=1.15
FALLBACK_INTERVAL_MINUTES=5
